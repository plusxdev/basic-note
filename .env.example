# basic note 환경변수 템플릿
# 이 파일을 .env.local로 복사한 뒤 본인 Supabase 프로젝트 값으로 채우세요.
#   cp .env.example .env.local
#
# 값은 Supabase 대시보드 → Project Settings → API 에서 확인합니다.
# 두 값 모두 NEXT_PUBLIC_* 이라 클라이언트 번들에 포함됩니다(공개 전제).
# 실데이터 보호는 클라이언트 E2E 암호화가 담당합니다.

# Supabase 프로젝트 URL (예: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — "anon" "public" 라벨이 붙은 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 로컬 개발 전용(선택) ──────────────────────────────────────────────────
# 동기화는 기본적으로 prod 빌드(NODE_ENV=production)에서만 켜집니다.
# 로컬 dev에서도 Supabase 동기화를 테스트하려면 아래를 "true"로:
# NEXT_PUBLIC_ENABLE_SYNC=true
